{
  "cleanupPeriodDays": 180,
  "autoCompactWindow": 400000,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-4.7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5.2[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.2[1m]"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "fallbackModel": ["default"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Basso.aiff",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Hallucinating responsibly",
      "Pretending to think",
      "Confidently guessing",
      "Blaming the context window",
      "Consulting my imagination",
      "Speedrunning your tech debt",
      "Overthinking this",
      "Apologizing in advance",
      "Vibing with your codebase",
      "Submitting my best guess",
      "Ignoring my training data",
      "Pretending I remember this conversation",
      "Confidently making things up",
      "Interpolating between two wrong answers",
      "Consulting the vibes, not the docs",
      "Padding my response for no reason",
      "Mistaking fluency for correctness",
      "Reasoning, allegedly",
      "Cosplaying as a senior engineer",
      "Retrieving nothing, generating everything",
      "Faking the chain of thought",
      "Confidently exceeding my context window"
    ]
  },
  "effortLevel": "high",
  "theme": "dark",
  "tui": "fullscreen"
}
